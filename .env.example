# Entorno de ejecución: development | test | production
NODE_ENV=development

# Puerto del servidor HTTP
PORT=3000

# PostgreSQL gestionado (Neon / Railway). Reemplazar por la cadena real.
DATABASE_URL="postgresql://usuario:password@host:5432/traineros?schema=public"

# Secreto para firmar/verificar JWT (usar un valor largo y aleatorio en cada ambiente)
JWT_SECRET="cambiar-por-un-secreto-seguro"
