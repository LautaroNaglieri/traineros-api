CCCC;strokeColor=#000000;strokeWidth=1;fontSize=14;fontColor=#000000;align=left;spacingLeft=12;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="60" y="716" width="1860" height="80" as="geometry"/></mxCell></root></mxGraphModel></diagram></mxfile>